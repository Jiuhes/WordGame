{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordgame.local/schemas/games.schema.json",
  "title": "Games Index",
  "type": "object",
  "required": ["games"],
  "additionalProperties": false,
  "properties": {
    "games": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[a-z0-9_-]+$"
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string"
          },
          "desc": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        }
      }
    }
  }
}
