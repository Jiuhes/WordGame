{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wordgame.local/schemas/game.schema.json",
  "title": "Word Game",
  "type": "object",
  "required": ["title", "scenes"],
  "additionalProperties": true,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "entryScene": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "additionalProperties": true,
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {},
          "max": {
            "type": "number"
          }
        }
      }
    },
    "initialState": {
      "type": "object"
    },
    "phases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "systemRules": {
      "type": "object",
      "properties": {
        "afterChoice": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/systemRule"
          }
        },
        "beforeRender": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/systemRule"
          }
        },
        "choiceRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/choiceRule"
          }
        }
      },
      "additionalProperties": true
    },
    "collectibles": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/collectible"
          }
        },
        "clues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/collectible"
          }
        }
      },
      "additionalProperties": true
    },
    "scenes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/scene"
      }
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "contentBlocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contentBlock"
          }
        },
        "choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/choice"
          }
        },
        "conditions": {
          "$ref": "#/$defs/condition"
        },
        "disabledReason": {
          "type": "string"
        },
        "tags": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": ["content"]
            },
            {
              "required": ["contentBlocks"]
            }
          ]
        }
      ]
    },
    "contentBlock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "narrator",
            "danger",
            "safe",
            "clue",
            "item",
            "ghost",
            "boss",
            "hero",
            "rival",
            "zombie",
            "wife",
            "husband",
            "secret",
            "dialogue",
            "raw-html"
          ]
        },
        "text": {
          "type": "string"
        },
        "html": {
          "type": "string"
        },
        "speaker": {
          "type": "string",
          "minLength": 1
        },
        "eyebrow": {
          "type": "string",
          "minLength": 1
        },
        "emphasis": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "aside": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": ["type", "text"]
        },
        {
          "required": ["type", "html"]
        }
      ]
    },
    "choice": {
      "type": "object",
      "required": ["text"],
      "additionalProperties": true,
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "next": {
          "type": "string",
          "minLength": 1
        },
        "reset": {
          "type": "boolean"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "conditions": {
          "$ref": "#/$defs/condition"
        },
        "visibility": {
          "$ref": "#/$defs/condition"
        },
        "disabledReason": {
          "type": "string"
        },
        "confirmText": {
          "type": "string"
        },
        "irreversible": {
          "type": "boolean"
        },
        "once": {
          "type": "boolean"
        },
        "tags": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "phase": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "conditions": {
          "$ref": "#/$defs/condition"
        }
      },
      "additionalProperties": true
    },
    "systemRule": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "when": {
          "$ref": "#/$defs/condition"
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action"
          }
        },
        "goto": {
          "type": "string",
          "minLength": 1
        },
        "once": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "collectible": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "icon": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "advanceTime",
            "adjust",
            "set",
            "addTag",
            "removeTag",
            "gainItem",
            "loseItem",
            "gainClue",
            "loseClue",
            "pushUnique",
            "removeValue"
          ]
        },
        "key": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "value": {},
        "tag": {
          "type": "string"
        },
        "item": {
          "type": "string"
        },
        "clue": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "choiceRule": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["disable", "hide"]
        },
        "reason": {
          "type": "string"
        },
        "when": {
          "$ref": "#/$defs/condition"
        },
        "match": {
          "type": "object",
          "properties": {
            "tagsAny": {
              "$ref": "#/$defs/stringArray"
            },
            "tagsAll": {
              "$ref": "#/$defs/stringArray"
            },
            "sceneTagsAny": {
              "$ref": "#/$defs/stringArray"
            },
            "sceneTagsAll": {
              "$ref": "#/$defs/stringArray"
            },
            "next": {
              "type": "string",
              "minLength": 1
            },
            "sceneId": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "conditionRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "op"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": [
            "eq",
            "ne",
            "gt",
            "gte",
            "lt",
            "lte",
            "includes",
            "notIncludes",
            "exists"
          ]
        },
        "value": {}
      }
    },
    "condition": {
      "anyOf": [
        {
          "$ref": "#/$defs/conditionRule"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["all"],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["any"],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["not"],
          "properties": {
            "not": {
              "$ref": "#/$defs/condition"
            }
          }
        }
      ]
    }
  }
}
