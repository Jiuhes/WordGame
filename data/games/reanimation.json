  "systemRules": {
    "afterChoice": [
      {
        "id": "dark-mode-on",
        "when": {
          "key": "battery",
          "op": "lte",
          "value": 0
        },
        "actions": [
          {
            "type": "addTag",
            "tag": "dark_mode"
          }
        ]
      },
      {
        "id": "dark-mode-off",
        "when": {
          "key": "battery",
          "op": "gt",
          "value": 0
        },
        "actions": [
          {
            "type": "removeTag",
            "tag": "dark_mode"
          }
        ]
      },
      {
        "id": "unstable-on",
        "when": {
          "key": "sanity",
          "op": "lte",
          "value": 2
        },
        "actions": [
          {
            "type": "addTag",
            "tag": "unstable"
          }
        ]
      },
      {
        "id": "unstable-off",
        "when": {
          "key": "sanity",
          "op": "gt",
          "value": 2
        },
        "actions": [
          {
            "type": "removeTag",
            "tag": "unstable"
          }
        ]
      },
      {
        "id": "isolated-on",
        "when": {
          "key": "trust",
          "op": "lte",
          "value": 1
        },
        "actions": [
          {
            "type": "addTag",
            "tag": "isolated"
          }
        ]
      },
      {
        "id": "isolated-off",
        "when": {
          "key": "trust",
          "op": "gt",
          "value": 1
        },
        "actions": [
          {
            "type": "removeTag",
            "tag": "isolated"
          }
        ]
      },
      {
        "id": "system-breakdown",
        "once": true,
        "when": {
          "key": "sanity",
          "op": "lte",
          "value": 0
        },
        "goto": "breakdown_end"
      },
      {
        "id": "system-replacement",
        "once": true,
        "when": {
          "all": [
            {
              "key": "time",
              "op": "gte",
              "value": 9
            },
            {
              "key": "sealed_room",
              "op": "eq",
              "value": false
            }
          ]
        },
        "goto": "replacement_end"
      }
    ],
    "choiceRules": [
      {
        "action": "disable",
        "when": {
          "key": "tags",
          "op": "includes",
          "value": "dark_mode"
        },
        "match": {
          "tagsAny": ["requires_light", "requires_power"]
        },
        "reason": "地下层彻底黑了下去，你现在做不了这种依赖照明和电源的操作。"
      },
      {
        "action": "disable",
        "when": {
          "key": "tags",
          "op": "includes",
          "value": "unstable"
        },
        "match": {
          "tagsAny": ["precise_logic"]
        },
        "reason": "你的精神状态已经开始失真，做不出这种精细判断。"
      },
      {
        "action": "disable",
        "when": {
          "key": "tags",
          "op": "includes",
          "value": "isolated"
        },
        "match": {
          "tagsAny": ["needs_backup"]
        },
        "reason": "现在已经没人愿意替你站台，这类协作方案行不通了。"
      },
      {
        "action": "disable",
        "when": {
          "key": "phase",
          "op": "eq",
          "value": "late"
        },
        "match": {
          "tagsAny": ["early_only"]
        },
        "reason": "你已经错过了这条窗口，医院开始按夜间异常流程收口。"
      },
      {
        "action": "disable",
        "when": {
          "key": "phase",
          "op": "eq",
          "value": "final"
        },
        "match": {
          "tagsAny": ["early_only"]
        },
        "reason": "现在已经太迟了，只剩终局处理还来得及。"
      }
    ]
  },
  "scenes": {
    "intro": {
      "title": "最后一班夜班",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "凌晨两点十七分，停尸房的登记台只亮着一盏旧台灯。你刚签完交接表，最深处的冷柜传来第二下闷响。第一下还能解释成压缩机，第二下不行。"
        },
        {
          "type": "danger",
          "text": "值班手册写得很清楚: 今夜共有七具遗体，全部封存完毕，不需要二次确认。"
        },
        {
          "type": "clue",
          "text": "你却记得最里面那格 307 号冷柜，今晚本来应该是空的。"
        }
      ],
      "choices": [
        {
          "text": "先发消息叫保安上来，别一个人扛",
          "next": "security_call",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "adjust",
              "key": "trust",
              "amount": 1
            },
            {
              "type": "set",
              "key": "called_help",
              "value": true
            }
          ]
        },
        {
          "text": "先去冷库门口确认 307 到底有没有人动过",
          "next": "cold_room_door",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        },
        {
          "text": "先去主任办公室，查今晚留下了什么记录",
          "next": "office_search",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        }
      ]
    },
