    "cold_room_door": {
      "title": "307 号冷柜",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "冷库门半掩着，地砖上有一行正在融化的水痕，一直拖到最深处的 307 号冷柜。柜门没有完全合拢，像是有人从里面试着推过。"
        },
        {
          "type": "danger",
          "text": "空气冷得过分，鼻腔里却能闻到一股新鲜的铁锈味。"
        }
      ],
      "choices": [
        {
          "text": "直接拉开 307 号冷柜",
          "next": "drawer_check",
          "actions": [
