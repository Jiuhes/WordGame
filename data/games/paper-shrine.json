    "west_room": {
      "title": "西厢房纸门",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "西厢房门板薄得像一张被浸过油的黄纸，门内堆满了没烧完的纸扎人和寿衣样本。阁楼口就在最里侧，偏偏上面垂下来一截刚被谁摸过的红线。"
        },
        {
          "type": "item",
          "text": "你隐约觉得，婆婆并不是在替自己准备后事，而是在给别人留退路。"
        }
      ],
      "choices": [
        {
          "text": "用祠堂钥匙开门，上阁楼翻木箱",
          "next": "hidden_mezzanine",
          "conditions": {
            "key": "items",
            "op": "includes",
            "value": "祠堂钥匙"
          },
          "disabledReason": "门锁还是老黄铜的，没有钥匙，你很难不惊动里面的东西。",
