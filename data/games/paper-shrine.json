  "scenes": {
    "intro": {
      "title": "头七回村",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "你赶在子时前回到老宅祠堂，为刚下葬的婆婆守头七。院门刚关上，灵堂里的长明灯就猛地晃了一下，像是有人从棺后轻轻吹了口气。"
        },
        {
          "type": "danger",
          "text": "村里人送你进门前反复叮嘱: 今晚不能让第二炷香灭，也不能回答井边有人叫你的乳名。"
        }
      ],
      "choices": [
        {
          "text": "先去灵堂，把香火续上",
          "next": "mourning_hall",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        },
        {
          "text": "先去账房，看婆婆生前到底留下了什么",
          "next": "ledger_room",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        },
        {
          "text": "先去井台附近确认动静从哪儿来的",
          "next": "well_courtyard",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        }
      ]
    },
    "mourning_hall": {
      "title": "灵堂里的第二炷香",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "灵牌前的纸灰堆得很整齐，像有人刚替你收拾过。婆婆的棺木停在最里侧，棺钉已经封好，偏偏棺盖边缘仍留着一线比夜风更冷的湿气。"
        },
        {
          "type": "clue",
          "text": "你刚把新香插稳，香头忽然同时朝井台方向偏过去。"
        }
      ],
      "choices": [
        {
          "text": "凑近棺盖，看看里面为什么会有潮气",
          "next": "open_coffin",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "adjust",
              "key": "incense",
              "amount": -1
            }
          ]
        },
        {
          "text": "去偏院给大姑妈打电话，问她祠堂旧规",
          "next": "aunt_call",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "adjust",
              "key": "resolve",
              "amount": 1
            }
          ]
        },
        {
          "text": "跟着湿脚印往回廊深处走",
          "next": "lantern_corridor",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "adjust",
              "key": "sanity",
              "amount": -1
            }
          ]
        }
      ]
    },
    "ledger_room": {
      "title": "账房夹层",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "账房里有股潮纸和旧墨的味道。算盘上还停着半粒没拨回去的珠子，像有人在很慌的时候被迫中途停手。"
        },
        {
          "type": "secret",
          "text": "你在抽屉夹层里摸到一把黄铜钥匙和一页被血渍粘住的旧账，账上记的不是香油钱，而是多年前某次“借命”的支出。"
        }
      ],
      "choices": [
        {
          "text": "带走钥匙和账页，去西厢房找能对应上的东西",
          "next": "west_room",
          "tags": ["precise"],
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "gainItem",
              "item": "祠堂钥匙"
            },
            {
              "type": "gainClue",
              "clue": "血账页"
            },
            {
              "type": "adjust",
              "key": "evidence",
              "amount": 1
            }
          ]
        },
        {
          "text": "先打电话问大姑妈，账上的借命到底借给了谁",
          "next": "aunt_call",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        },
        {
          "text": "拿着账页回灵堂，对照牌位看看缺了谁",
          "next": "mourning_hall",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        }
      ]
    },
    "well_courtyard": {
      "title": "井台回声",
      "contentBlocks": [
        {
          "type": "narrator",
          "text": "院里那口封了半辈子的老井今晚竟然揭着木盖，井绳湿得发亮，一路拖到青石地上。井沿内壁有人拿钉子刻了一个名字，反复描了很多遍，像怕死后没人认得。"
        },
        {
          "type": "ghost",
          "text": "你弯下腰时，井里正好传来一句轻得像水泡破开的乳名。"
        }
      ],
      "choices": [
        {
          "text": "用竹竿把井绳上的东西勾上来",
          "next": "lantern_corridor",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "gainItem",
              "item": "铜铃"
            },
            {
              "type": "gainClue",
              "clue": "井底名字"
            },
            {
              "type": "adjust",
              "key": "evidence",
              "amount": 1
            }
          ]
        },
        {
          "text": "不听井里的声音，转去回廊追湿脚印",
          "next": "lantern_corridor",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            }
          ]
        },
        {
          "text": "去偏院打电话，先问活人比问井下的东西靠谱",
          "next": "aunt_call",
          "actions": [
            {
              "type": "advanceTime",
              "amount": 1
            },
            {
              "type": "adjust",
              "key": "resolve",
              "amount": 1
            }
